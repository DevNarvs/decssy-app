# Copy this file to .env.local and fill in real values.
# Do NOT commit .env.local.

# ── Convex ──────────────────────────────────────────────────────────────
# Set automatically by `npx convex dev` on first run.
NEXT_PUBLIC_CONVEX_URL=

# ── App URL ─────────────────────────────────────────────────────────────
# Optional override for share-link base URL. Leave UNSET (or omit this
# line) for the normal case — share links will use the current origin
# automatically: localhost in dev, your Vercel domain in prod.
#
# Set this only when you need to mimic a different origin for testing
# (e.g., generate prod-style links while developing locally to verify
# the receive flow with a real phone scanner).
# NEXT_PUBLIC_APP_URL=https://decssy-app.vercel.app

# ──────────────────────────────────────────────────────────────────────────
# AUTH-RELATED SECRETS DO NOT GO HERE.
# Convex Auth secrets (provider client IDs/secrets, SITE_URL, JWT keys)
# live in CONVEX's deployment env, set via the Convex CLI:
#   npx convex env set AUTH_GOOGLE_ID <client-id>
#   npx convex env set AUTH_GOOGLE_SECRET <client-secret>
#   npx convex env set SITE_URL https://decssy.app
# ──────────────────────────────────────────────────────────────────────────
